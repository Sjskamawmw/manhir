PORT=3000

# URL do seu frontend no Netlify.
# Em desenvolvimento pode deixar http://localhost:8888 ou http://127.0.0.1:5500
FRONTEND_ORIGIN=http://localhost:8888

# URL do seu Hugging Face Space rodando o executor da IA.
# Exemplo local: http://127.0.0.1:8080
# Exemplo Space: https://seu-usuario-seu-space.hf.space
HUGGINGFACE_SPACE_URL=http://127.0.0.1:8080

# Modelo usado no payload OpenAI-compatible do Space.
LLAMA_MODEL=manhir
